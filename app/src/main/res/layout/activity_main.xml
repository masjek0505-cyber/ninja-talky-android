<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent" android:layout_height="match_parent"
    android:orientation="vertical" android:padding="24dp" android:gravity="center">
    <EditText android:id="@+id/etIp" android:layout_width="match_parent" android:layout_height="wrap_content" android:hint="IP Server" android:text="192.168.1.10" />
    <EditText android:id="@+id/etName" android:layout_width="match_parent" android:layout_height="wrap_content" android:hint="Nama" android:text="Budi" />
    <EditText android:id="@+id/etChannel" android:layout_width="match_parent" android:layout_height="wrap_content" android:hint="Channel" android:text="JAKARTA" />
    <Button android:id="@+id/btnConnect" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="CONNECT" />
    <Button android:id="@+id/btnPtt" android:layout_width="200dp" android:layout_height="200dp" android:layout_marginTop="50dp" android:text="TEKAN BICARA" android:enabled="false" />
    <TextView android:id="@+id/tvStatus" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="20dp" android:text="Status: Offline" />
</LinearLayout>
